{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "npm run start",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  },
  "variables": {
    "NODE_ENV": "production",
    "PORT": "3000"
  }
}
